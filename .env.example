# Модель и квантизация
MODEL=Qwen/Qwen2.5-3B-Instruct-AWQ
QUANTIZATION=awq

# Тег образа vLLM.
# v0.6.3 — последняя версия, стабильно работающая под WSL2.
# Более новые падают с "UVA is not available" (см. docs/wsl-notes.md).
VLLM_TAG=v0.6.3

# Ограничения под 6 GB VRAM. Обоснование — docs/vram-math.md
MAX_MODEL_LEN=4096
GPU_MEM_UTIL=0.80
MAX_NUM_SEQS=8

API_PORT=8000
HF_CACHE=~/.cache/huggingface
HF_TOKEN=
